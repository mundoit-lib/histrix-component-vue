# Host del backend Histrix (sin slash final). Ej: https://erp.cliente.com
# Se vuelca a config.fixApi (host efectivo) y a config.apiUrl como fallback.
VITE_HISTRIX_HOST=https://histrix.example.com

# Base de datos / cliente Histrix por defecto (el {db} de /api/db/{db}/...).
VITE_HISTRIX_DB=demo

# Credenciales OAuth2 (password grant) del cliente de la app.
VITE_CLIENT_ID=changeme-client-id
VITE_CLIENT_SECRET=changeme-client-secret

# Opcional: endpoint que lista las DBs visibles (apiDBQuery / selector de base).
# Si lo dejás vacío se asume `${VITE_HISTRIX_HOST}/api/db/`.
VITE_HISTRIX_MAIN_URL=

# Opcional: usuario de prueba (se muestra en la pantalla de login como ayuda).
VITE_TEST_EMAIL=
VITE_TEST_PASSWORD=
